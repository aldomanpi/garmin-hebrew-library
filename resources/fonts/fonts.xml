<?xml version="1.0"?>
<!--
  Pre-compiled AngelCode BMFont (.fnt + .png sprite sheet).
  Generated by tools/gen_font.py from Alef-Garmin.ttf.

  Three size-named IDs are defined so HebrewText.View can load the correct
  font for HebrewText.FONT_SIZE_SMALL / _MEDIUM / _LARGE.  Currently all
  three reference the same 22 px bitmap.  To enable visually distinct sizes,
  regenerate with gen_font.py (font-size 16 and font-size 28), rename the
  outputs to hebrewSmall.fnt/.png and hebrewLarge.fnt/.png, then update
  the filenames in hebrewFontSmall and hebrewFontLarge below.
-->
<fonts>
  <font id="hebrewFontSmall" filename="hebrew.fnt" antialias="true"/>
  <font id="hebrewFont"      filename="hebrew.fnt" antialias="true"/>
  <font id="hebrewFontLarge" filename="hebrew.fnt" antialias="true"/>
</fonts>
