<?xml version="1.0"?>
<!--
  Pre-compiled AngelCode BMFont (.fnt + .png sprite sheet).
  Generated by tools/gen_font.py from Alef-Garmin.ttf at three sizes:
    hebrewSmall.fnt + hebrewSmall.png   font-size 16
    hebrew.fnt      + hebrew.png        font-size 22 (default / medium)
    hebrewLarge.fnt + hebrewLarge.png   font-size 28
  HebrewText.View selects between them via the :fontSize constructor option
  (HebrewText.FONT_SIZE_SMALL / _MEDIUM / _LARGE).
-->
<fonts>
  <font id="hebrewFontSmall" filename="hebrewSmall.fnt" antialias="true"/>
  <font id="hebrewFont"      filename="hebrew.fnt"      antialias="true"/>
  <font id="hebrewFontLarge" filename="hebrewLarge.fnt" antialias="true"/>
</fonts>
